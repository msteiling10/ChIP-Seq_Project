rule narrowpeak_to_bigwig:
  input:
    peaks = "macs3_peaks/pe/{sample}_peaks.narrowPeak",
    sizes = "chromsizes.genome"
  output:
    bw = "bigbed/pe/{sample}.bw"
  shell:
    """
    awk '{print $1"\t"$2"\t"$3"\t"$7}' {input}.narrowPeak | sort -k1,1 -k2,2n > {sample}.bedGraph
    bedGraphToBigWig {sample}.bedGraph chromsizes.genome output.bw
    """
